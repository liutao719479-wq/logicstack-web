<script setup>
import { computed, onBeforeUnmount, onMounted, ref } from 'vue'
import { Close, Grid, Menu, Moon, MoreFilled, Search, Sunny } from '@element-plus/icons-vue'
import { useRoute } from 'vue-router'
import { useTheme } from '@/composables/useTheme'

const drawerOpen = ref(false)
const scrolled = ref(false)
const route = useRoute()
const { isNight, toggleTheme } = useTheme()
const isHeroCover = computed(() => route.name === 'home' && !scrolled.value)
const navItems = [
  { name: '首页', to: '/' },
  { name: '工程实践', to: '/engineering' },
  { name: '在线工具箱', to: '/tools' },
  { name: '交易研究', to: '/trading' },
  { name: '宏观地图', to: '/macro' },
  { name: '实战项目', to: '/projects' },
  { name: '关于', to: '/about' }
]

function updateScrollState() {
  scrolled.value = window.scrollY > 12
}

onMounted(() => {
  updateScrollState()
  window.addEventListener('scroll', updateScrollState, { passive: true })
})

onBeforeUnmount(() => {
  window.removeEventListener('scroll', updateScrollState)
})
</script>

<template>
  <header class="site-header" :class="{ 'hero-cover': isHeroCover }">
    <nav class="hao-nav" aria-label="主导航">
      <div class="nav-group">
        <div class="nav-left">
          <button class="nav-icon app-entry" type="button" aria-label="站点菜单">
            <el-icon><Grid /></el-icon>
          </button>
          <router-link class="site-name" to="/" aria-label="LogicStack 首页">
            <span class="brand-bracket brand-bracket--left">[</span>
            <span class="brand-text">LogicStack</span>
            <span class="brand-bracket">]</span>
          </router-link>
        </div>

        <div class="nav-menu">
          <router-link v-for="item in navItems" :key="item.to" class="site-page" :to="item.to">
            {{ item.name }}
          </router-link>
        </div>

        <div class="nav-right">
          <button
            class="nav-icon"
            type="button"
            :title="isNight ? '切换到白天模式' : '切换到黑夜模式'"
            :aria-label="isNight ? '切换到白天模式' : '切换到黑夜模式'"
            @click="toggleTheme"
          >
            <el-icon><Sunny v-if="isNight" /><Moon v-else /></el-icon>
          </button>
          <button class="nav-icon desktop-tool" type="button" title="站内搜索" aria-label="站内搜索">
            <el-icon><Search /></el-icon>
          </button>
          <button class="nav-icon desktop-tool" type="button" title="更多" aria-label="更多">
            <el-icon><MoreFilled /></el-icon>
          </button>
          <button class="nav-icon mobile-trigger" type="button" aria-label="打开导航" @click="drawerOpen = true">
            <el-icon><Menu /></el-icon>
          </button>
        </div>
      </div>
    </nav>
  </header>

  <el-drawer v-model="drawerOpen" direction="rtl" size="78%" :show-close="false" class="mobile-drawer">
    <template #header>
      <div class="drawer-head">
        <span class="drawer-brand">[ LogicStack ]</span>
        <button type="button" aria-label="关闭导航" @click="drawerOpen = false">
          <el-icon><Close /></el-icon>
        </button>
      </div>
    </template>
    <nav class="mobile-nav" aria-label="手机导航">
      <router-link v-for="item in navItems" :key="item.to" :to="item.to" @click="drawerOpen = false">
        {{ item.name }}
      </router-link>
      <button class="drawer-theme" type="button" @click="toggleTheme">
        <el-icon><Sunny v-if="isNight" /><Moon v-else /></el-icon>
        {{ isNight ? '白天模式' : '黑夜模式' }}
      </button>
    </nav>
  </el-drawer>
</template>

